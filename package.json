{
  "name": "mattis-abenteuer",
  "version": "0.1.0",
  "private": true,
  "description": "A 3D voxel survival-crafting castle warfare game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,html}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "peerjs": "^1.5.5",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^6.0.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Alexander Herttrich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AHerttrich/mattis-abenteuer.git"
  }
}
