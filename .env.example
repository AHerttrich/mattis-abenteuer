# ─── Game Configuration ───────────────────────────────────────
# World seed for procedural generation (optional, random if empty)
VITE_WORLD_SEED=42

# Render distance in chunks (default: 8)
VITE_RENDER_DISTANCE=8

# Debug mode (shows grid, FPS counter, chunk borders)
VITE_DEBUG=false

# ─── Development ──────────────────────────────────────────────
# Dev server port
VITE_PORT=3000
